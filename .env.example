# ===========================================
# Neon PostgreSQL (Structured Data)
# ===========================================
# Sign up at https://neon.tech (free tier available)
# Get connection string from Dashboard → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/medical?sslmode=require"

# ===========================================
# Pinecone (Vector Search for Clinical Notes)
# ===========================================
# Sign up at https://pinecone.io
# Create index: medical-notes, 1536 dimensions, cosine metric
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=medical-notes

# ===========================================
# OpenAI (Embeddings + Chat)
# ===========================================
OPENAI_API_KEY=sk-...

# ===========================================
# Cohere (Optional - Reranking)
# ===========================================
COHERE_API_KEY=...

# ===========================================
# Privacy Settings
# ===========================================
# Set to 'true' to obscure PII in query results
# Names become pseudonyms (Patient-A7B3), dates show year only (1985-XX-XX)
# Locations are redacted, and clinical notes have PII patterns removed
OBSCURE_PII=false
