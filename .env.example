# ===========================================
# Neon PostgreSQL (Structured Data)
# ===========================================
# Sign up at https://neon.tech (free tier available)
# Get connection string from Dashboard → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/medical?sslmode=require"

# ===========================================
# Pinecone (Vector Search for Clinical Notes)
# ===========================================
# Sign up at https://pinecone.io
# Create index: medical-notes, 1536 dimensions, cosine metric
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=medical-notes

# ===========================================
# OpenAI (Embeddings + Chat)
# ===========================================
OPENAI_API_KEY=sk-...
# Optional: route all OpenAI calls through the LiteLLM proxy (budgets + dogfood).
# Leave unset to hit api.openai.com directly. See infra/litellm/README.md.
# OPENAI_BASE_URL=https://parsity-litellm.fly.dev

# ===========================================
# Cohere (Optional - Reranking)
# ===========================================
COHERE_API_KEY=...

# ===========================================
# Privacy Settings
# ===========================================
# Set to 'true' to obscure PII in query results
# Names become pseudonyms (Patient-A7B3), dates show year only (1985-XX-XX)
# Locations are redacted, and clinical notes have PII patterns removed
OBSCURE_PII=false

# ===========================================
# LangSmith (Observability - Required for HITL)
# ===========================================
# Sign up at https://smith.langchain.com
# Get API key from Settings → API Keys
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=medical-rag

# ===========================================
# Cal.com (Appointment Scheduling)
# ===========================================
# Sign up at https://cal.com (free tier available)
# Get API key from Settings → Developer → API Keys
# Create an event type and get its ID from the URL (/event-types/[ID])
CAL_API_KEY=cal_live_...
CAL_EVENT_TYPE_ID=123456

# ===========================================
# Retell AI (EXTENSION — appointment confirmation call)
# ===========================================
# Voice call after a Cal.com booking. Create an agent in the Retell dashboard
# (prompt uses {{patient_name}} + {{appointment_time}}), buy a number, assign it.
RETELL_API_KEY=
RETELL_FROM_NUMBER=          # the Retell number you bought (E.164, e.g. +15551234567)
DEMO_PHONE_NUMBER=          # DEMO: ring your own phone instead of the patient's

# ===========================================
# LMS — Course site (Clerk auth + its OWN Neon database)
# ===========================================
# SEPARATE Neon project from DATABASE_URL above. The medical-rag DB gets
# `prisma db push --force-reset` during class; LMS student progress must
# never live there. Use the POOLED connection string.
LMS_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/lms?sslmode=require"

# Clerk (https://dashboard.clerk.com) — create an application, then:
#   Dashboard → set sign-up to "restricted" (invite-only) and enable
#   email magic-link / verification code.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Comma-separated admin email allowlist (who can reach /admin)
LMS_ADMIN_EMAILS=brian@parsity.io

# Public base URL of the deployed site (used for Clerk invite redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
