# ===========================================================
# LiteLLM proxy secrets — copy to .env (which is gitignored).
# This file just documents the shape.
# ===========================================================

# OpenAI key — the key the proxy uses for the wildcard route, so students can
# call ANY OpenAI model (gpt-4o-mini, text-embedding-3-small, gpt-4.1-nano, ...).
# Use a DEDICATED classroom key, not a personal one — all student spend funnels
# through it (per-student caps still apply).
OPENAI_API_KEY=sk-proj-...

# LiteLLM admin key — used to mint per-student keys. Keep it OFF rosters
# and CSVs. Generate with: echo "sk-$(openssl rand -hex 32)"
LITELLM_MASTER_KEY=sk-...

# Postgres for key/budget state. In production this is the Neon `litellm`
# database (set as a Fly secret); locally, docker-compose provides its own.
# DATABASE_URL=postgresql://user:pw@host/litellm?sslmode=require

# Where the proxy listens (used by 2-new-cohort.sh)
PROXY_URL=https://parsity-litellm.fly.dev
