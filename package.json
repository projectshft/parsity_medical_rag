{
  "name": "medical-rag",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:evals": "RUN_EVALS=1 vitest run lib/evals",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "ingest": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/ingest-coherent.ts",
    "vectorize": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/vectorize.ts",
    "bible:fixed": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/bible/chunk-fixed.ts",
    "bible:smart": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/bible/chunk-smart.ts",
    "bible:audit": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/bible/audit.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^0.10.0",
    "@pinecone-database/pinecone": "^4.0.0",
    "@prisma/client": "^6.0.0",
    "ai": "^4.1.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cohere-ai": "^7.17.0",
    "jose": "^6.2.3",
    "langsmith": "^0.7.5",
    "next": "15.1.6",
    "openai": "^4.77.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv": "^16.4.7",
    "postcss": "^8",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^2.1.0"
  },
